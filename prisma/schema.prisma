generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Reserva {
  reserva_id           Int                @id @default(autoincrement())
  livro_id             Int
  usuario_id           Int
  reserva_data_reserva DateTime           @db.DateTime(0)
  reserva_posicao_fila Int
  reserva_status       Int

  historico ReservaHistorico[]

  @@map("reserva")
}

model ReservaHistorico {
  reserva_historico_id     Int      @id @default(autoincrement())
  reserva_historico_data   DateTime @db.DateTime(0)
  reserva_historico_status Int?
  reserva_id               Int

  reserva Reserva @relation(fields: [reserva_id], references: [reserva_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reserva_historico_reserva")

  @@index([reserva_id], map: "fk_reserva_historico_reserva_idx")
  @@map("reserva_historico")
}